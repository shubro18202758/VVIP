{
  "name": "command-deck",
  "version": "0.2.0",
  "description": "VVIP Convoy Orchestration Command Center — GIS map viewer, LLM chat, WebGPU traffic simulation",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:cpu": "NODE_OPTIONS=--max-old-space-size=512 vite dev",
    "build": "vite build",
    "build:cpu": "NODE_OPTIONS=--max-old-space-size=1024 vite build",
    "preview": "vite preview",
    "serve": "node build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test:integration": "node tests/integration-agent.mjs"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^4.0.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.15.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/node": "^22.0.0",
    "@webgpu/types": "^0.1.52",
    "eslint": "^9.16.0",
    "prettier": "^3.4.0",
    "svelte": "^5.15.0",
    "svelte-check": "^4.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "maplibre-gl": "^5.0.0",
    "@deck.gl/core": "^9.1.0",
    "@deck.gl/layers": "^9.1.0",
    "@deck.gl/aggregation-layers": "^9.1.0",
    "@deck.gl/geo-layers": "^9.1.0",
    "@deck.gl/mapbox": "^9.1.0"
  }
}
