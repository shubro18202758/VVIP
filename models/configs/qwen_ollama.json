# Qwen 3.5 9B configuration for Ollama
# Optimized for 8GB VRAM on NVIDIA RTX 4070
{
    "model": "qwen3.5:9b-q4_K_M",
    "parameters": {
        "num_ctx": 8192,
        "num_predict": 2048,
        "temperature": 0.3,
        "top_p": 0.9,
        "top_k": 40,
        "repeat_penalty": 1.1,
        "num_gpu": 99,
        "num_thread": 8
