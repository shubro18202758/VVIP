    "notes": {
        "quantization": "Q4_K_M — best quality/size tradeoff for 8GB VRAM",
        "estimated_vram_mb": 5632,
        "kv_cache_policy": "KV cache grows with context length; keep num_ctx <= 8192 to stay under budget",
        "concurrent_requests": "NEVER allow concurrent inference — serialized via OllamaBridge asyncio.Lock"
    }
}
