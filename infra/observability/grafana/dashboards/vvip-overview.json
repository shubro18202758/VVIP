{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "GPU VRAM Usage",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "nvidia_gpu_memory_used_bytes / nvidia_gpu_memory_total_bytes * 100",
          "legendFormat": "VRAM %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "VRAM by Component",
      "type": "piechart",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "5632", "legendFormat": "Ollama/Qwen (5632MB)" },
        { "expr": "409", "legendFormat": "ONNX Inference (409MB)" },
        { "expr": "307", "legendFormat": "CUDA Overhead (307MB)" },
        { "expr": "nvidia_gpu_memory_free_bytes / 1048576", "legendFormat": "Free" }
      ]
    },
    {
      "title": "GPU Temperature",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 0 },
      "targets": [
        { "expr": "nvidia_gpu_temperature_celsius", "legendFormat": "GPU °C" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "title": "GPU Utilization",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 0 },
      "targets": [
        { "expr": "nvidia_gpu_utilization_gpu_percent", "legendFormat": "GPU %" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "title": "GPU Power Draw",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 0 },
      "targets": [
        { "expr": "nvidia_gpu_power_draw_watts", "legendFormat": "Watts" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 130 }
            ]
          }
        }
      }
    },
    {
      "title": "LLM Token Generation Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "rate(vvip_llm_tokens_generated_total[1m])", "legendFormat": "tok/sec" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 }
        }
      }
    },
    {
      "title": "LLM Inference Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(vvip_llm_inference_duration_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(vvip_llm_inference_duration_seconds_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(vvip_llm_inference_duration_seconds_bucket[5m]))", "legendFormat": "p99" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "MCP Tool Call Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(vvip_mcp_tool_duration_seconds_bucket[5m]))", "legendFormat": "{{ tool_name }} p95" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "MCP Tool Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        { "expr": "rate(vvip_mcp_tool_errors_total[5m])", "legendFormat": "{{ tool_name }} — {{ error }}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "API Request Latency (convoy-brain)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(vvip_api_request_duration_seconds_bucket{service=\"convoy-brain\"}[5m]))", "legendFormat": "{{ endpoint }} p95" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "API Request Latency (traffic-oracle)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(vvip_api_request_duration_seconds_bucket{service=\"traffic-oracle\"}[5m]))", "legendFormat": "{{ endpoint }} p95" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "pgRouting Query Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 30 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(vvip_pgrouting_query_duration_seconds_bucket[5m]))", "legendFormat": "{{ query_type }} p95" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "pgvector Similarity Search",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 30 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(vvip_pgvector_search_duration_seconds_bucket[5m]))", "legendFormat": "p95" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "DB Connection Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 30 },
      "targets": [
        { "expr": "vvip_db_pool_available_connections", "legendFormat": "Available" },
        { "expr": "vvip_db_pool_total_connections", "legendFormat": "Total" },
        { "expr": "vvip_db_pool_idle_connections", "legendFormat": "Idle" }
      ]
    },
    {
      "title": "Orchestrator Tool Rounds per Turn",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 38 },
      "targets": [
        { "expr": "vvip_orchestrator_tool_rounds_total", "legendFormat": "Rounds (max 6)" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 4 },
              { "color": "red", "value": 6 }
            ]
          }
        }
      }
    },
    {
      "title": "Signal-Ingress Channel Utilization",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 38 },
      "targets": [
        { "expr": "vvip_ingress_channel_utilization", "legendFormat": "feed_rx" },
        { "expr": "vvip_ingress_batch_channel_utilization", "legendFormat": "batch_rx" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      }
    },
    {
      "title": "Anomaly Detection Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 46 },
      "targets": [
        { "expr": "rate(vvip_anomaly_detections_total[5m])", "legendFormat": "{{ anomaly_type }}" },
        { "expr": "rate(vvip_observations_processed_total[5m])", "legendFormat": "Total observations" }
      ]
    },
    {
      "title": "Container Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 46 },
      "targets": [
        { "expr": "container_memory_usage_bytes{name=~\"vvip-.*\"} / 1048576", "legendFormat": "{{ name }} (MB)" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "decmbytes" }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["vvip", "convoy", "gpu"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "VVIP Convoy Platform — Overview",
  "uid": "vvip-overview",
  "version": 1
}
